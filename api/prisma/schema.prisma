datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PolicyMode {
  AUTO
  CONFIRM
  STEP_UP
}

model ToolPolicy {
  id        String     @id @default(cuid())
  userId    String
  toolName  String
  riskLevel RiskLevel
  mode      PolicyMode
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, toolName])
}

enum Provider {
  github
}

model AllowedResource {
  id           String   @id @default(cuid())
  userId       String
  provider     Provider
  resourceType String   // "repo"
  resourceId   String   // e.g. "org/name"
  createdAt    DateTime @default(now())

  @@unique([userId, provider, resourceType, resourceId])
}

enum Decision {
  ALLOWED
  DENIED
  CONFIRM_REQUIRED
  STEP_UP_REQUIRED
  ERROR
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  requestId  String
  toolName   String
  inputJson  String
  decision   Decision
  reason     String?
  reasoning  String?
  executed   Boolean  @default(false)
  resultJson String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model StepUpSession {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

